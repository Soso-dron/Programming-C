#include <stdio.h>
#include <math.h>

double perimetr(double a, double b, double c){
	return a + b + c;
}
double Square(double a, double b, double c){
	double p = (a + b + c)/2;
	return sqrt(p*(p-a)*(p-b)*(p-c));
}
int Rich(double a, double b, double c){
	return (a+b>c )&&(a+c>b)&&(b+c>a);
}

int main(){
	double a, b, c;
	printf("Write a, b, c: ");
	scanf("%lf %lf %lf", &a, &b, &c);
	
	if(!Rich(a, b, c)){
		printf("Rerror, triada no \n");
		return 1;
	}
	printf("Perimetr = %.2f\n", perimetr(a, b, c));
	printf("Square = %.2f\n", Square(a, b, c));
	return 0;
}
