#include <stdio.h>
int main() {
	double arr[3][3] = {
		{23, 45, 7},
		{34, 69, 9},
		{5, 6, 70}
	};
	double glav_diag = 0, poboch_diag = 0;
	for(int i = 0; i <3; i++) {
		glav_diag += arr[i][i];
	}
	for(int i = 0; i < 3; i++) {
		poboch_diag += arr[i][2-i];
	}
	printf("Part 1\n");
	printf("\n");
	printf("Summ first diag: %.2f\n", glav_diag);
	printf("Summ poboch diag: %.2f\n", poboch_diag);






int matrix[2][2], square[2][2];
	printf("Part 2\n");
    printf("Write elements matrix 2x2:\n");
    for (int i = 0; i < 2; i++) {
        for (int j = 0; j < 2; j++) {
            printf("elements [%d][%d]: ", i, j);
            scanf("%d", &matrix[i][j]);
        }
    }

    square[0][0] = matrix[0][0] * matrix[0][0] + matrix[0][1] * matrix[1][0];
    square[0][1] = matrix[0][0] * matrix[0][1] + matrix[0][1] * matrix[1][1];
    square[1][0] = matrix[1][0] * matrix[0][0] + matrix[1][1] * matrix[1][0];
    square[1][1] = matrix[1][0] * matrix[0][1] + matrix[1][1] * matrix[1][1];
    
    printf("\Your matrix:\n");
    for (int i = 0; i < 2; i++) {
        for (int j = 0; j < 2; j++) {
            printf("%d ", matrix[i][j]);
        }
        printf("\n");
    }
    
    printf("\Square matrix (M * M):\n");
    for (int i = 0; i < 2; i++) {
        for (int j = 0; j < 2; j++) {
            printf("%d ", square[i][j]);
        }
        printf("\n");
    }
    
    return 0;
}
